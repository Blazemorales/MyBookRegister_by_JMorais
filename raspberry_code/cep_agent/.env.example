# ── Backend (mybookregister rodando na mesma Pi) ─────────────────────
BACKEND_URL=http://127.0.0.1:8000
RPI_DEVICE_TOKEN=troque-por-token-seguro

# ── MQTT (broker Mosquitto na Pi) ─────────────────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=1883

# Usuário/senha e TLS — só necessários quando o cep_agent roda fora da
# LAN da Pi (ex.: Render) e o broker está exposto na internet.
# Deixe em branco para conexão local sem autenticação.
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS=false

# Tópico MQTT em que a ESP32 publica leituras de sensor
# Formato esperado: número ou JSON {"valor": <float>, "unidade": "<str>"}
MQTT_TOPICO_SENSOR=jmorais/esp32s3/sensor/leitura

# Tópico em que lampada_stats.py publica a duração de cada sessão da lâmpada
MQTT_TOPICO_LAMPADA=jmorais/lampada/sessao

# ── Canal CEP (identifica o dispositivo no site) ──────────────────────
CANAL=default

# ── Canal CEP dedicado às sessões da lâmpada (carta I-MR separada) ────
CANAL_LAMPADA=lampada

# ── Tamanho do subgrupo para Carta X̄-R (5 leituras → 1 ponto) ────────
# I-MR usa n=1 (cada leitura é um ponto individual).
XR_SUBGRUPO_N=5

# ── Critério de "defeituoso" para Carta P (opcional) ─────────────────
# Deixe em branco para não enviar carta P automaticamente.
# Exemplo: "x < 9.5"  →  leituras abaixo de 9.5 são contadas como defeituosas.
P_CRITERIO_DEFEITO=

# ── Portas do agente (FastAPI) ────────────────────────────────────────
AGENT_PORT=8080

# ── Timezone ─────────────────────────────────────────────────────────
TZ=America/Sao_Paulo

# ── Agendador interno (diário 03:00 / mensal dia 1 03:05) ─────────────
# Deixe true no uso padrão (tudo na Pi). Coloque false se os relatórios
# passarem a ser disparados por outro agendador (ex.: Render Cron Job —
# ver raspberry_code/render-free.yaml) — evita gerar o mesmo relatório
# duas vezes. Não afeta o ingest.py (ponte MQTT), que continua rodando.
SCHEDULER_ENABLED=true

# ── Ponte MQTT→Socket.IO (ingest.py) ───────────────────────────────────
# Deixe true no uso padrão (tudo na Pi, com acesso ao broker local).
# Coloque false num deploy sem acesso ao broker (ex.: Render free — ver
# raspberry_code/render-free.yaml), pra não ficar tentando conectar à
# toa. O ingest.py de verdade continua rodando na Pi.
INGEST_ENABLED=true
