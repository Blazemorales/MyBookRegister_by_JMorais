# Credenciais do Postgres do compose. O backend monta DATABASE_URL a partir delas.
POSTGRES_USER=tpe
POSTGRES_PASSWORD=tpe
POSTGRES_DB=tpe

# Segredos do backend.
# Gere SECRET_KEY com:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Token compartilhado entre backend e o RPi (ou o rpi-sim).
RPI_DEVICE_TOKEN=dev-rpi-token

# CORS — origens permitidas no FastAPI e no Socket.IO (separadas por vírgula).
ALLOWED_ORIGINS=http://localhost:3000

# Segredo HMAC do middleware de auth do Next.js (front/proxy.ts).
# Gere com:
#   python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=

# URL pública do backend que o browser usa para Socket.IO e que entra na
# CSP do Next (build arg, inlinado pelo Next). Em dev local: localhost:8000.
NEXT_PUBLIC_SOCKET_URL=http://localhost:8000

# Opcionais
ACCESS_TOKEN_EXPIRE_MINUTES=60
LOG_LEVEL=INFO
# Intervalo de emissão do rpi-sim (em segundos).
INTERVALO=2
# Rate-limit por conexão RPi no canal Socket.IO (mensagens/segundo).
# 0 ou negativo desliga. Burst máximo = mesmo valor (1s de margem).
RPI_RATE_LIMIT_HZ=20
# Limite servidor-side de pontos no replay (subscribe_relatorio.replay_n).
# Cliente pode pedir até esse valor; pedidos maiores são cortados.
STREAM_REPLAY_MAX=200
